{
  "name": "@kidd-cli/cli",
  "version": "0.11.8",
  "description": "DX companion CLI for the kidd framework",
  "keywords": [
    "cli",
    "codegen",
    "kidd",
    "scaffolding"
  ],
  "homepage": "https://github.com/joggrdocs/kidd/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/joggrdocs/kidd/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/kidd.git",
    "directory": "packages/cli"
  },
  "bin": {
    "kidd": "./bin/kidd.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown && mkdir -p dist/lib && cp -r src/lib/templates dist/lib/templates && cp ../../pnpm-workspace.yaml dist/pnpm-workspace.yaml",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kidd-cli/bundler": "workspace:*",
    "@kidd-cli/config": "workspace:*",
    "@kidd-cli/core": "workspace:*",
    "@kidd-cli/utils": "workspace:*",
    "fs-extra": "^11.3.4",
    "ink": "^7.0.0",
    "liquidjs": "catalog:",
    "picocolors": "^1.1.1",
    "react": "^19.2.5",
    "tsdown": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.2.14",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  }
}
