import { cli } from '@maltty/core'
{% if includeConfig %}
import { configSchema } from './config.js'
{% endif %}
void cli({
  name: '{{ name }}',
  version: '0.0.0',
  description: '{{ description }}',
  commands: import.meta.dirname + '/commands',
{% if includeConfig %}  config: {
    schema: configSchema,
  },
{% endif %}})
