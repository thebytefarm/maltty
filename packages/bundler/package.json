{
  "name": "@maltty/bundler",
  "version": "1.0.0-rc.0",
  "description": "Programmatic bundler for maltty CLI tools powered by tsdown",
  "keywords": [
    "bundler",
    "cli",
    "maltty",
    "tsdown",
    "typescript"
  ],
  "homepage": "https://github.com/thebytefarm/maltty/tree/main/packages/bundler",
  "bugs": {
    "url": "https://github.com/thebytefarm/maltty/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebytefarm/maltty.git",
    "directory": "packages/bundler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@maltty/config": "workspace:*",
    "@maltty/utils": "workspace:*",
    "es-toolkit": "catalog:",
    "ts-pattern": "catalog:",
    "tsdown": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  }
}
