{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "isolatedDeclarations": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./src/test/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
