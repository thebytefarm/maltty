{
  "name": "@maltty/config",
  "version": "1.0.0-rc.0",
  "description": "Build-time configuration for maltty CLIs",
  "keywords": [
    "cli",
    "config",
    "configuration",
    "maltty",
    "typescript"
  ],
  "homepage": "https://github.com/thebytefarm/maltty/tree/main/packages/config",
  "bugs": {
    "url": "https://github.com/thebytefarm/maltty/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebytefarm/maltty.git",
    "directory": "packages/config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@maltty/utils": "workspace:*",
    "c12": "4.0.0-beta.5",
    "es-toolkit": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  }
}
