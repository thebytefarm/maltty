{
  "name": "@examples/authenticated-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx api/server.ts & API_PID=$!; maltty dev --cwd cli; kill $API_PID 2>/dev/null",
    "api": "tsx api/server.ts",
    "dev": "maltty dev --cwd cli",
    "build": "maltty build --cwd cli",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "maltty": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@maltty/cli": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
