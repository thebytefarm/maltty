{
  "name": "maltty-mono",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "build": "turbo run build --filter='./packages/*'",
    "build:examples": "turbo run build --filter='./examples/*'",
    "dev": "turbo run dev",
    "stories": "pnpm build && maltty stories --cwd packages/maltty",
    "docs:dev": "ciderpress dev",
    "docs:build": "ciderpress build",
    "docs:serve": "ciderpress serve",
    "docs:sync": "ciderpress sync",
    "docs:check": "ciderpress check",
    "docs:clean": "ciderpress clean",
    "clean": "pnpm clean:build && pnpm clean:cache && pnpm clean:npm",
    "clean:build": "pnpm dlx rimraf -g 'packages/*/dist' 'examples/*/dist' '.ciderpress/dist' '.ciderpress/content' 'packages/*/*.tsbuildinfo' '*.tsbuildinfo'",
    "clean:cache": "pnpm dlx rimraf -g '.turbo' 'packages/*/.turbo' '.ciderpress/cache' 'node_modules/.cache'",
    "clean:npm": "pnpm dlx rimraf -g 'node_modules' 'packages/*/node_modules' 'examples/*/node_modules'",
    "reset": "pnpm clean && pnpm install",
    "test": "turbo run test test:exports",
    "test:integration": "vitest run --project integration",
    "test:exports": "vitest run --project exports",
    "test:coverage": "turbo run test:coverage --filter='./packages/*'",
    "test:watch": "turbo run build --filter='./packages/*' && vitest",
    "typecheck": "turbo run typecheck --filter='./packages/*'",
    "check": "turbo run typecheck --filter='./packages/*' && pnpm lint && pnpm format",
    "validate": "turbo run typecheck --filter='./packages/*' && turbo run test --filter='./packages/*' && pnpm lint && pnpm format",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:initial": "changeset version && pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ciderpress/theme": "1.0.0-rc.3",
    "@clack/prompts": "^1.2.0",
    "@maltty/cli": "workspace:*",
    "@rspress/core": "^2.0.16",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "@vitest/coverage-v8": "catalog:",
    "ciderpress": "1.0.0-rc.6",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-security": "^4.0.0",
    "laufen": "^1.3.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "ts-pattern": "catalog:",
    "turbo": "^2.9.6",
    "vite": "^8.0.10",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.1"
}
