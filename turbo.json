{
  "$schema": "https://raw.githubusercontent.com/vercel/turborepo/main/packages/turbo-types/schemas/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:coverage": {
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#test:integration": {
      "dependsOn": [
        "@examples/simple#build",
        "@examples/advanced#build",
        "@examples/icons#build",
        "@examples/diagnostic-output#build",
        "@examples/authenticated-service#build"
      ]
    },
    "//#test:exports": {
      "dependsOn": [
        "@maltty/bundler#build",
        "@maltty/cli#build",
        "@maltty/config#build",
        "@maltty/core#build",
        "@maltty/utils#build"
      ]
    }
  }
}
